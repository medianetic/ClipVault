{
  "name": "clipvault",
  "private": true,
  "version": "1.5.0",
  "description": "ClipVault - A high-performance Electron frontend for yt-dlp",
  "author": "Nick Weschkalnies",
  "type": "module",
  "repository": "https://github.com/medianetic/ClipVault/",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "electron:build": "electron-builder --config electron-builder.json5",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "screenshots": "node tools/update_screenshots.js",
    "auto-screenshots": "node tools/auto_update_screenshots.js"
  },
  "build": {
    "files": [
      "dist-electron/**/*",
      "dist/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@vueuse/core": "^14.3.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.15.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-vue-next": "^1.0.0",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.2.2",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.7",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.26"
  }
}
